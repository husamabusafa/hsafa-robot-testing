# Copy this to `.env` and fill in your own values.
# `.env` is git-ignored.

# --- Gemini Live -----------------------------------------------------------
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Override the default Gemini Live model if yours isn't accepted.
# GEMINI_MODEL=gemini-3.1-flash-live-preview

# --- OpenRouter (for examples/new-teck-test.py) ----------------------------
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Override the default vision model if needed.
# OPENROUTER_VL_MODEL=qwen/qwen2.5-vl-72b-instruct:nitro

# Audio is routed through Reachy Mini's built-in GStreamer pipeline
# (`reachy.media`); no device-selection env vars are needed. Make sure the
# Reachy daemon is running *without* the `--no-media` flag so it owns the
# camera/audio hardware.
